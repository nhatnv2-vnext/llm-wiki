System/node_modules/
System/*.log

# Auto-gen RAG index (rebuild bằng `npm run index-vault`)
02_Wiki/00_Dashboard/Vault_Index.json

# Obsidian per-user
.obsidian/workspace*.json
.obsidian/cache/

# Obsidian plugin binaries — team tự cài qua UI, chỉ commit data.json (settings)
.obsidian/plugins/*/main.js
.obsidian/plugins/*/styles.css
.obsidian/plugins/*/manifest.json
# (giữ lại data.json để chia sẻ cấu hình)
!.obsidian/plugins/*/data.json

# File rác Obsidian
Untitled.base
Untitled.md

